{
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ],
      "@/styles/*": [
        "styles/*"
      ],
      "@/components/*": [
        "components/*"
      ],
      "@/icons/*": [
        "icons/*"
      ],
      "@/fonts/*": [
        "fonts/*"
      ],
      "@/types": [
        "types/index"
      ],
      "@/utils/*": [
        "utils/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    ".next/types/**/*.ts",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "components*/**/*.ts",
    "components*/**/*.tsx",
    "icons/**/*.ts",
    "icons/**/*.tsx",
    "next-env.d.ts",
    "types/**/*.ts",
    "types/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx",
    "utils/motions.ts",
    "components/custom-texts.tsx",
    "utils/styles.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
