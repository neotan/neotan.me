  "description": "Showcases Neo's excellent works!😉",
  "scripts": {
    "build": "npm run build:mdx && next build",
    "build:mdx": "node ./scripts/compile-mdx.mjs ./content",
    "dev": "next dev --port 4000",
    "dev:clean": "npm run clean && next dev",
    "dev:mdx": "chokidar ./tailwind.config.js ./content/**/*.mdx ./scripts/mdx.js -c \"npm run build:mdx\"",
    "lint": "next lint --fix",
    "start": "next start",
    "clean": "rm -rf node_modules package-lock.json yarn.lock .temp .next .turbo pnpm-lock.yaml"
  },
  "dependencies": {
    "@agentofuser/remark-oembed": "^1.0.4",
    "@code-hike/mdx": "^0.8.2",
    "@pondorasti/remark-img-links": "^1.0.8",
    "@reach/dialog": "^0.18.0",
    "@remark-embedder/core": "^3.0.1",
    "@remark-embedder/transformer-oembed": "^3.0.0",
    "clsx": "^1.2.1",
    "daisyui": "^2.51.5",
    "date-fns": "^2.29.3",
    "framer-motion": "^8.4.2",
    "fuse.js": "^6.6.2",
    "gray-matter": "^4.0.3",
    "next": "^13.3.4",
    "next-images": "^1.8.4",
    "next-mdx-remote": "^4.4.1",
    "next-seo": "^5.15.0",
    "next-superjson-plugin": "^0.5.7",
    "next-themes": "^0.2.1",
    "ramda": "^0.28.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.7.1",
    "react-use": "^17.4.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-slug": "^5.1.0",
    "rehype-twemojify": "^3.1.0",
    "remark-gfm": "^3.0.1",
    "remark-images": "^3.1.0",
    "shared-types": "workspace:*",
    "shiki": "^0.14.1",
    "superjson": "^1.12.3",
    "tailwind-merge": "^1.8.1",
    "tailwind-scrollbar": "^2.1.0",
    "ui": "workspace:*",
    "utils": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.9",
