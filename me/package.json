    "dotenv": "^16.0.3",
    "eslint": "^8.31.0",
    "eslint-config-custom": "workspace:*",
    "eslint-config-next": "^13.1.1",
    "eslint-plugin-import": "^2.26.0",
    "fs-extra": "^11.1.1",
    "postcss": "^8.4.21",
    "postcss-import": "^15.1.0",
    "tailwind-config-custom": "workspace:*",
    "tailwindcss": "^3.2.4",
    "tsconfig": "workspace:*",
    "typescript": "^5.2.2"
  }
